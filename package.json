{
  "name": "easyjobapps-chrome-extension",
  "version": "1.0.0",
  "description": "AI-powered job application Chrome extension",
  "main": "src/index.js",
  "scripts": {
    "start": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack       --config webpack.config.js --mode production --devtool source-map --json stats.json && node ./output.js",
    "servers": "concurrently -n \"WATCHSERVER,STRIPE,PDFLATEX\" -c \"blue,red,red\" \"npm run watchserver\" \"npm run stripe\" \"npm run latex\"",
    "dev": "NODE_ENV=development concurrently -n \"WEBPACK,SERVERS\" -c \"blue,green\" \"npm run start\" \"npm run servers\"",
    "staging": "concurrently -n \"START,SERVERS,WATCHBUILD\" -c \"blue,green,red\" \"npm run start\" \"npm run servers\" \"npm run watchbuild\"",
    "prod": "node scripts/deploy-production.js",
    "test:deploy": "node scripts/deploy-production.test.js",
    "watchserver": "npx nodemon --config nodemon_server.json",
    "watchbuild": "npx nodemon --config nodemon_build.json",
    "latex": "source ../pdflatex/bin/activate && python ../pdflatex/server.py",
    "loadlatex": "bash -i -c 'goto pdflatex && eactivate && python ../pdflatex/server.py'",
    "stripe": "./stripe listen --forward-to localhost:3002/stripe/event"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@metamask/detect-provider": "^2.0.0",
    "@webauthn/server": "^0.1.3",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "driver": "^1.0.0",
    "driver.js": "^1.3.1",
    "ejs": "^3.1.10",
    "ethereumjs-util": "^7.1.5",
    "ethers": "^6.13.2",
    "express-session": "^1.18.0",
    "fingerprintjs2": "^2.1.4",
    "google-auth-library": "^9.13.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "nodemon": "^3.1.4",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "sqlite3": "^5.1.7",
    "thread-loader": "^4.0.4",
    "throttle": "^1.0.3",
    "url": "^0.11.4"
  },
  "devDependencies": {

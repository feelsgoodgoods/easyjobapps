    "@babel/preset-env": "^7.24.8",
    "@babel/preset-react": "^7.24.7",
    "axios": "^1.7.2",
    "babel-loader": "^8.3.0",
    "concurrently": "^9.0.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^5.2.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^7.3.1",
    "file-loader": "^6.2.0",
    "fs": "^0.0.1-security",
    "html-webpack-plugin": "^5.3.1",
    "nodemon": "^3.1.4",
    "pdfjs-dist": "^4.5.136",
    "raw-loader": "^4.0.2",
    "style-loader": "^2.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.1",
    "webpack-ext-reloader": "^1.1.13",
